---
// src/components/Header.astro

import { headerMenu } from '@data/menu';
import Logo from '@components/Logo.astro';
import { Menu, X } from 'lucide-astro';

const currentPath = Astro.url.pathname;
const isCurrentPage = (link: string) => {
    if (link === '/') return currentPath === '/';
    return currentPath.startsWith(link);
};

const waLink = 'https://wa.me/6281274203815?text=Halo%20Jakobi%2C%20saya%20ingin%20konsultasi%20gratis.';
---

<!-- Tombol hamburger — fixed di luar header agar selalu di atas -->
<button
    id="mobile-menu-button"
    class="fixed top-6 right-6 z-[60] p-2 cursor-pointer bg-transparent border-none lg:hidden"
    aria-label="Toggle Menu"
    aria-expanded="false"
>
    <span class="menu-icon block">
        <Menu size={26} class="text-primary" />
    </span>
    <span class="close-icon hidden">
        <X size={26} class="text-white" />
    </span>
</button>

<header id="site-header" class="fixed top-0 z-50 w-full left-0 transition-all duration-300">
    <div class="site-container mx-auto px-4 sm:px-6">
        <div
            id="header-inner"
            class="flex justify-between items-center h-20 mt-3 px-6 bg-white rounded-xl shadow-sm border border-gray-100 transition-all duration-300"
        >
            <!-- Logo -->
            <Logo />

            <!-- Navigasi Desktop -->
            <nav class="hidden lg:flex items-center gap-6" aria-label="Navigasi Utama">
                <ul class="flex gap-6 items-center list-none m-0 p-0">
                    {headerMenu.map((item) => (
                        <li>
                            <a
                                href={item.link}
                                class:list={[
                                    'text-sm font-medium transition-colors duration-200 py-1 border-b-2',
                                    isCurrentPage(item.link)
                                        ? 'text-primary border-primary font-semibold'
                                        : 'text-gray-700 border-transparent hover:text-primary hover:border-primary/50',
                                ]}
                                aria-current={isCurrentPage(item.link) ? 'page' : undefined}
                            >
                                {item.name}
                            </a>
                        </li>
                    ))}
                </ul>

                <!-- CTA Button -->
                <a
                    href={waLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 bg-secondary text-white font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-secondary-dark transition-colors shadow-sm"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-4 h-4 fill-current" aria-hidden="true"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
                    Konsultasi Gratis
                </a>
            </nav>
        </div>
    </div>
</header>

<script>
    document.addEventListener('astro:page-load', () => {
        const headerInner = document.getElementById('header-inner');
        if (!headerInner) return;

        const onScroll = () => {
            if (window.scrollY > 20) {
                headerInner.classList.add('shadow-md');
                headerInner.classList.remove('shadow-sm');
            } else {
                headerInner.classList.remove('shadow-md');
                headerInner.classList.add('shadow-sm');
            }
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    });
</script>
