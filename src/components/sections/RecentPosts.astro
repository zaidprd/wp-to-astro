---
import { client, urlFor } from '../../lib/sanity';
import Button from '@components/ui/Button.astro';
import { getPaddingClass, getBackgroundColor } from '@utils/styleUtils';
import type { PaddingSize, ThemeColor } from '@utils/styleUtils';

export interface Props {
    content?: {
        eyebrow?: string;
        title?: string;
        description?: string;
        button?: {
            text: string;
            link: string;
            variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark';
        };
    };
    background?: ThemeColor;
    padding?: PaddingSize;
    paddingTop?: PaddingSize;
    paddingBottom?: PaddingSize;
    postsToShow?: number;
    category?: string;
}

const { content, background = 'base', postsToShow = 3, category } = Astro.props;

const bgColor = getBackgroundColor(background);
const paddingClass = getPaddingClass({
    padding: Astro.props.padding,
    paddingTop: Astro.props.paddingTop,
    paddingBottom: Astro.props.paddingBottom,
});

const allPosts = await client.fetch(`
*[_type == "post"] | order(publishedAt desc) {
    title,
    "slug": slug.current,
    excerpt,
    "publishDate": publishedAt,
    "featuredImage": mainImage { asset->{...}, alt },
    categories[]->{ title }
}`);

const filteredPosts = allPosts
    .filter((post: any) => !category || post.categories?.some((cat: any) => cat.title === category))
    .slice(0, postsToShow);

function formatDate(dateStr: string) {
    if (!dateStr) return '';
    return new Date(dateStr).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<section class:list={['relative', bgColor, paddingClass]}>
    <div class="site-container mx-auto px-4 sm:px-6">

        {(content?.eyebrow || content?.title || content?.description) && (
            <div class="text-center mb-12 max-w-2xl mx-auto">
                {content?.eyebrow && (
                    <div class="text-secondary font-bold text-sm uppercase tracking-wider mb-3" data-aos="fade-up">
                        {content.eyebrow}
                    </div>
                )}
                {content?.title && (
                    <h2 class="text-headline mb-4" data-aos="fade-up" data-aos-delay="100">{content.title}</h2>
                )}
                {content?.description && (
                    <p class="text-body-base leading-relaxed" data-aos="fade-up" data-aos-delay="150">{content.description}</p>
                )}
            </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {filteredPosts.map((post: any, i: number) => {
                const imgUrl = post.featuredImage
                    ? urlFor(post.featuredImage).width(480).height(270).format('webp').quality(80).url()
                    : null;
                const categoryLabel = post.categories?.[0]?.title;
                return (
                    <a
                        href={`/${post.slug}`}
                        class="group flex flex-col bg-white rounded-xl border border-gray-100 overflow-hidden hover:border-secondary/40 hover:shadow-md transition-all duration-300"
                        data-aos="fade-up"
                        data-aos-delay={i * 100}
                    >
                        <div class="aspect-[16/9] overflow-hidden bg-background-light shrink-0">
                            {imgUrl ? (
                                <img
                                    src={imgUrl}
                                    alt={post.featuredImage?.alt || post.title}
                                    width="480"
                                    height="270"
                                    loading="lazy"
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center bg-primary/5">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                                </div>
                            )}
                        </div>

                        <div class="p-5 flex flex-col flex-1">
                            {categoryLabel && (
                                <span class="inline-block text-xs font-bold text-secondary uppercase tracking-wider mb-2">{categoryLabel}</span>
                            )}
                            <h3 class="font-bold text-headline text-base leading-snug mb-2 line-clamp-2 group-hover:text-primary transition-colors">
                                {post.title}
                            </h3>
                            {post.excerpt && (
                                <p class="text-body-base text-sm leading-relaxed line-clamp-2 mb-4 flex-1">{post.excerpt}</p>
                            )}
                            <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-100">
                                <span class="text-xs text-gray-400">{formatDate(post.publishDate)}</span>
                                <span class="text-xs font-semibold text-primary flex items-center gap-1 group-hover:gap-2 transition-all">
                                    Baca
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                </span>
                            </div>
                        </div>
                    </a>
                );
            })}
        </div>

        {content?.button && (
            <div class="text-center mt-10" data-aos="fade-up">
                <Button
                    text={content.button.text}
                    link={content.button.link}
                    variant={content.button.variant || 'primary'}
                />
            </div>
        )}
    </div>
</section>
