---
// src/components/sections/ProcessSection.astro

const steps = [
    {
        number: '01',
        title: 'Konsultasi Awal',
        description: 'Anda menghubungi kami via WhatsApp atau form kontak. Tim kami akan mendiskusikan kebutuhan, ruang lingkup proyek, dan estimasi waktu — tanpa biaya.',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    },
    {
        number: '02',
        title: 'Pengumpulan Data',
        description: 'Tim kami melakukan survei lapangan, wawancara, dan analisis data sekunder yang relevan untuk membangun fondasi analisis yang kuat dan akurat.',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
    },
    {
        number: '03',
        title: 'Analisis & Penyusunan',
        description: 'Pakar kami menganalisis aspek teknis, finansial, pasar, hukum, dan lingkungan. Laporan disusun secara sistematis sesuai standar industri.',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><polyline points="1 20 23 20"/></svg>`,
    },
    {
        number: '04',
        title: 'Presentasi & Revisi',
        description: 'Laporan final dipresentasikan kepada Anda. Kami menyertakan sesi tanya jawab dan revisi hingga hasil memenuhi kebutuhan dan ekspektasi Anda.',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    },
];
---

<section class="py-base bg-background-light">
    <div class="site-container mx-auto px-4 sm:px-6">

        <!-- Header -->
        <div class="text-center mb-14 max-w-2xl mx-auto">
            <div class="inline-block text-secondary font-bold text-sm uppercase tracking-wider mb-3" data-aos="fade-up">Cara Kerja Kami</div>
            <h2 class="text-headline mb-4" data-aos="fade-up" data-aos-delay="100">Proses Kerja yang Terstruktur</h2>
            <p class="text-body-base leading-relaxed" data-aos="fade-up" data-aos-delay="150">
                Empat langkah sistematis dari konsultasi awal hingga laporan final yang siap digunakan.
            </p>
        </div>

        <!-- Steps Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 relative">
            <!-- Connector line (desktop only) -->
            <div class="hidden lg:block absolute top-12 left-[12.5%] right-[12.5%] h-0.5 bg-gradient-to-r from-secondary/20 via-secondary to-secondary/20 z-0" aria-hidden="true"></div>

            {steps.map((step, i) => (
                <div
                    class="relative bg-white rounded-xl p-7 shadow-sm border border-gray-100 hover:border-secondary/40 hover:shadow-md transition-all duration-300 z-10"
                    data-aos="fade-up"
                    data-aos-delay={i * 100}
                >
                    <!-- Nomor langkah -->
                    <div class="w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm mb-5 shadow-sm">
                        {step.number}
                    </div>

                    <!-- Ikon -->
                    <div class="text-secondary mb-4" set:html={step.icon} />

                    <h3 class="text-headline font-bold text-lg mb-3">{step.title}</h3>
                    <p class="text-body-base text-sm leading-relaxed">{step.description}</p>
                </div>
            ))}
        </div>

        <!-- CTA bawah -->
        <div class="text-center mt-12" data-aos="fade-up">
            <a
                href="https://wa.me/6281274203815?text=Halo%20Jakobi%2C%20saya%20ingin%20memulai%20konsultasi."
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-primary text-white font-semibold px-8 py-4 rounded-lg hover:bg-primary-dark transition-colors shadow-sm"
            >
                Mulai Konsultasi Sekarang
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
        </div>
    </div>
</section>
