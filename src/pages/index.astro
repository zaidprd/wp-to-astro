---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero.astro';
import SplitPanel from '@components/sections/SplitPanel.astro';
import Features from '@components/sections/Features.astro';
import RecentPosts from '@components/sections/RecentPosts.astro';
import ProcessSection from '@components/sections/ProcessSection.astro';
import TestimoniSection from '@components/sections/TestimoniSection.astro';
import Logos from '@components/sections/Logos.astro';

import { featureLists } from '@data/features';
import { logoLists } from '@data/logos';

import heroImage from '../assets/images/home/hero-jakobi.webp';
import styleGuideImage from '../assets/images/home/jasa-studi-kelayakan-1.webp';

// === SEO ===
const seoTitle = "Konsultan Studi Kelayakan Bisnis & Business Plan Terpercaya";
const seoDescription = "PT Jaya Konsultan Bisnis (Jakobi) — jasa studi kelayakan, business plan, dan riset pasar untuk UMKM dan korporasi Indonesia. Konsultasi gratis, tim berpengalaman 10+ tahun.";

// === FIX #7: Organization Schema ===
const orgSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "PT Jaya Konsultan Bisnis",
    "alternateName": "Jakobi",
    "url": "https://jayakonsultanbisnis.com",
    "telephone": "+6281274203815",
    "email": "info@jayakonsultanbisnis.com",
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "Jl. H Taha No 2K Kelapa Dua Kebon Jeruk",
        "addressLocality": "Jakarta Barat",
        "addressRegion": "DKI Jakarta",
        "postalCode": "11550",
        "addressCountry": "ID"
    },
    "sameAs": [
        "https://www.instagram.com/jayakonsultanbisnis"
    ]
});

// === Section Content ===
const heroContent = {
    title: 'Konsultan Studi Kelayakan & Business Plan Terpercaya',
    description: 'Solusi analisis mendalam dan perencanaan strategis untuk memastikan bisnis Anda layak dan menguntungkan. Melayani UMKM hingga korporasi di seluruh Indonesia.',
    buttons: [
        {
            text: 'Konsultasi Gratis via WhatsApp',
            link: 'https://wa.me/6281274203815?text=Halo%20Jakobi%2C%20saya%20ingin%20konsultasi%20gratis.',
            target: '_blank',
            variant: 'secondary' as const,
        },
        {
            text: 'Lihat Layanan Kami',
            link: '/layanan',
            variant: 'ghostLight' as const,
        },
    ],
    backgroundImage: heroImage,
    overlayOpacity: 0.65,
    trustBadges: [
        { value: '100+', label: 'Proyek Selesai' },
        { value: '10+', label: 'Tahun Pengalaman' },
        { value: '95%', label: 'Klien Puas' },
    ],
};

const pengertianSection = {
    eyebrow: "Apa Itu",
    headline: "Studi Kelayakan Bisnis (Feasibility Study)",
    description: `
        <p style="margin-bottom: 1rem; color: #4A5568;">Studi kelayakan adalah proses evaluasi komprehensif untuk menilai apakah suatu proyek atau rencana bisnis layak dilaksanakan dari berbagai aspek — teknis, finansial, pasar, hukum, dan lingkungan.</p>
        <p style="color: #4A5568;">Tujuan utamanya adalah memberikan dasar pengambilan keputusan yang kuat, meminimalkan risiko investasi, dan meningkatkan peluang keberhasilan proyek Anda.</p>
    `,
    image: {
        src: styleGuideImage,
        alt: "Ilustrasi konsultan sedang menyusun studi kelayakan bisnis"
    },
    buttons: [
        {
            text: 'Pelajari Lebih Lanjut',
            link: '/jasa-studi-kelayakan-bisnis',
            variant: 'primary' as const,
        }
    ],
};

const featuresSection = {
    eyebrow: "Mengapa Pilih Kami",
    title: "Keunggulan Jakobi",
    description: "Tim berpengalaman dengan metodologi terstruktur untuk menghasilkan laporan yang akurat, komprehensif, dan dapat diandalkan.",
    features: featureLists.main.features,
};

const recentPostsSection = {
    eyebrow: "Wawasan Bisnis",
    title: "Artikel Terbaru dari Tim Kami",
    description: "Dapatkan wawasan seputar studi kelayakan, business plan, dan strategi bisnis dari para ahli kami.",
    button: {
        text: "Lihat Semua Artikel",
        link: "/blog",
        variant: "primary" as const
    }
};

const logosSection = {
    eyebrow: "Portofolio Klien",
    logos: logoLists.main.logos
};

const FooterCta = {
    title: 'Siap Memulai Proyek Anda?',
    description: 'Konsultasi pertama GRATIS. Hubungi kami sekarang dan dapatkan gambaran solusi untuk kebutuhan bisnis Anda.',
    hideCta: false,
    button: {
        text: 'Chat WhatsApp Sekarang',
        link: 'https://wa.me/6281274203815?text=Halo%20Jakobi%2C%20saya%20ingin%20konsultasi%20gratis.',
        target: '_blank'
    }
};
---

<Layout
    title={seoTitle}
    description={seoDescription}
    schema={orgSchema}
    footerCta={FooterCta}
>
    <!-- Section 1: Hero -->
    <Hero content={heroContent} />

    <!-- Section 2: Layanan Utama (3 kartu) -->
    <section class="py-base bg-background-light">
        <div class="site-container mx-auto px-4 sm:px-6">
            <div class="text-center mb-12 max-w-2xl mx-auto">
                <div class="text-secondary font-bold text-sm uppercase tracking-wider mb-3" data-aos="fade-up">Layanan Unggulan</div>
                <h2 class="text-headline mb-4" data-aos="fade-up" data-aos-delay="100">Solusi Konsultasi Bisnis Lengkap</h2>
                <p class="text-body-base leading-relaxed" data-aos="fade-up" data-aos-delay="150">
                    Kami menyediakan tiga layanan utama yang saling melengkapi untuk mendukung keberhasilan bisnis Anda.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {[
                    {
                        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
                        title: 'Studi Kelayakan',
                        desc: 'Analisis mendalam dari aspek teknis, finansial, pasar, hukum, dan lingkungan untuk memastikan proyek Anda layak dilaksanakan.',
                        link: '/jasa-studi-kelayakan-bisnis',
                    },
                    {
                        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
                        title: 'Business Plan',
                        desc: 'Penyusunan rencana bisnis strategis dan terperinci untuk memandu arah perusahaan dan menarik investor atau penyandang dana.',
                        link: '/jasa-business-plan',
                    },
                    {
                        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><polyline points="1 20 23 20"/></svg>`,
                        title: 'Riset Pasar',
                        desc: 'Penelitian pasar yang akurat untuk memahami perilaku konsumen, tren industri, dan potensi pasar sebagai dasar strategi pemasaran.',
                        link: '/jasa-riset-pasar',
                    },
                ].map((service, i) => (
                    <a
                        href={service.link}
                        class="group bg-white rounded-xl p-8 shadow-sm border border-gray-100 hover:border-secondary/50 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col"
                        data-aos="fade-up"
                        data-aos-delay={i * 100}
                    >
                        <div class="w-14 h-14 rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white flex items-center justify-center mb-6 transition-colors duration-300" set:html={service.icon} />
                        <h3 class="text-headline font-bold text-xl mb-3 group-hover:text-primary transition-colors">{service.title}</h3>
                        <p class="text-body-base text-sm leading-relaxed flex-1 mb-5">{service.desc}</p>
                        <span class="text-sm font-semibold text-primary flex items-center gap-1 group-hover:gap-2 transition-all">
                            Pelajari Selengkapnya
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </span>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <!-- Section 3: Pengertian Studi Kelayakan (SplitPanel) -->
    <SplitPanel content={pengertianSection} imagePosition="right" background="base" padding="base" />

    <!-- Section 4: Keunggulan Kami (Features) -->
    <Features content={featuresSection} padding="base" background="light" />

    <!-- Section 5: Proses Kerja -->
    <ProcessSection />

    <!-- Section 6: Testimoni -->
    <TestimoniSection />

    <!-- Section 7: Artikel Blog Terbaru -->
    <RecentPosts content={recentPostsSection} background="light" padding="base" postsToShow={3} />

    <!-- Section 8: Logo Klien -->
    <Logos content={logosSection} background="base" padding="small" />
</Layout>
