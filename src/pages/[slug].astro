---
// src/pages/[slug].astro

import { client, urlFor } from '../lib/sanity';
import type { GetStaticPaths } from 'astro';
import Layout from '@layouts/Layout.astro';
import Date from '@components/ui/Date.astro';
import { marked } from 'marked';

export const prerender = true;

export const getStaticPaths: GetStaticPaths = async () => {
    const posts = await client.fetch(`*[_type == "post" && defined(slug.current)]{ "slug": slug.current }`);
    const staticPages = ['blog', 'contact', 'about', 'style-guide', 'privacy-policy'];
    return posts
        .filter((post: { slug: string }) => !staticPages.includes(post.slug))
        .map((post: { slug: string }) => ({ params: { slug: post.slug } }));
};

const { slug } = Astro.params;
if (!slug) throw new Error('Slug tidak ditemukan');

const post = await client.fetch(
`*[_type == "post" && slug.current == $slug][0]{
    title,
    "body": body[]{
        ...,
        markDefs[]{...}
    },
    "_markDefs": body[].markDefs[],
    excerpt,
    "publishDate": publishedAt,
    _updatedAt,
    "featuredImage": mainImage { asset->{...}, alt },
    categories[]->{ title }
}`, { slug });

if (!post) return Astro.redirect('/404');

const seoTitle       = post.title;
const seoDescription = post.excerpt || post.title;
const featuredImageUrl = post.featuredImage ? urlFor(post.featuredImage).width(1200).url() : undefined;

// Konversi PortableText ke HTML secara SSG (tanpa library external)
function portableTextToHtml(blocks: any[], markDefs: any[] = []): string {
    if (!Array.isArray(blocks)) return '';
    const escape = (t: string) => t.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const styleTag: Record<string, string> = {
        normal: 'p', h1: 'h1', h2: 'h2', h3: 'h3', h4: 'h4', h5: 'h5', h6: 'h6', blockquote: 'blockquote',
    };
    return blocks.map((block: any) => {
        if (block._type === 'image' && block.asset?._ref) {
            const src = urlFor(block).width(900).format('webp').quality(80).url();
            const alt = escape(block.alt || '');
            const caption = block.caption ? `<figcaption class="text-center text-sm text-gray-500 mt-2">${escape(block.caption)}</figcaption>` : '';
            return `<figure class="my-8"><img src="${src}" alt="${alt}" loading="lazy" class="w-full h-auto rounded-lg" />${caption}</figure>`;
        }
        if (block._type !== 'block') return '';
        const tag = styleTag[block.style || 'normal'] || 'p';
        const children = (block.children || []).map((child: any) => {
            let text = escape(child.text || '');
            const marks: string[] = child.marks || [];
            for (const mark of marks) {
                if (mark === 'strong') { text = `<strong>${text}</strong>`; continue; }
                if (mark === 'em') { text = `<em>${text}</em>`; continue; }
                if (mark === 'underline') { text = `<u>${text}</u>`; continue; }
                if (mark === 'strike-through') { text = `<s>${text}</s>`; continue; }
                if (mark === 'code') { text = `<code>${text}</code>`; continue; }
                const def = markDefs.filter(Boolean).find((d: any) => d && d._key === mark);
                if (def?._type === 'link') {
                    const rel = def.href?.startsWith('/') ? '' : 'noopener noreferrer nofollow';
                    const tgt = def.href?.startsWith('/') ? '' : ' target="_blank"';
                    text = `<a href="${escape(def.href || '#')}"${tgt}${rel ? ` rel="${rel}"` : ''}>${text}</a>`;
                }
            }
            return text;
        }).join('');
        return `<${tag}>${children}</${tag}>`;
    }).join('\n');
}

// Tandai link eksternal agar buka tab baru
const SITE_HOST = 'jayakonsultanbisnis.com';
function markExternalLinks(html: string): string {
    return html.replace(/<a\s+href="(https?:\/\/[^"]+)"/gi, (match, url) => {
        if (url.includes(SITE_HOST)) return match;
        return `<a href="${url}" target="_blank" rel="noopener noreferrer nofollow"`;
    });
}

// ✅ FIX #1 CRITICAL: Konten artikel sepenuhnya di-render saat build (SSG)
// Tidak ada lagi client:load — Google bisa baca semua konten di raw HTML
let bodyHtml: string | null = null;

if (typeof post.body === 'string') {
    bodyHtml = String(await marked(post.body));
} else if (Array.isArray(post.body)) {
    const extractedText: string = post.body
        .flatMap((block: any) => block.children || [])
        .map((span: any) => span.text || '')
        .join('\n');

    if (/##|\*\*|^- |\n##/m.test(extractedText)) {
        // Konten dengan raw markdown syntax
        bodyHtml = String(await marked(extractedText));
    } else {
        // Konten PortableText native dari Sanity Block Editor
        // Dikonversi ke HTML saat build time (SSG) — tidak ada client:load
        bodyHtml = portableTextToHtml(post.body, (post._markDefs || []).filter(Boolean));
    }
}

if (bodyHtml) bodyHtml = markExternalLinks(bodyHtml);

// Estimasi waktu baca
const wordCount = bodyHtml ? bodyHtml.replace(/<[^>]+>/g, '').split(/\s+/).filter(Boolean).length : 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200));

// FIX #6: Article JSON-LD Schema
const articleSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.title,
    "description": post.excerpt || post.title,
    ...(featuredImageUrl && { "image": featuredImageUrl }),
    "datePublished": post.publishDate,
    "dateModified": post._updatedAt || post.publishDate,
    "author": {
        "@type": "Organization",
        "name": "PT Jaya Konsultan Bisnis"
    },
    "publisher": {
        "@type": "Organization",
        "name": "PT Jaya Konsultan Bisnis",
        "url": "https://jayakonsultanbisnis.com",
        "logo": {
            "@type": "ImageObject",
            "url": "https://jayakonsultanbisnis.com/favicon.webp"
        }
    }
});
---

<Layout
    title={seoTitle}
    description={seoDescription}
    image={featuredImageUrl}
    ogType="article"
    schema={articleSchema}
>
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="bg-background-light border-b border-gray-200">
        <div class="site-container mx-auto px-4 py-3 pt-28">
            <ol class="flex items-center gap-2 text-sm text-gray-500 flex-wrap">
                <li><a href="/" class="hover:text-primary transition-colors">Beranda</a></li>
                <li class="text-gray-400" aria-hidden="true">/</li>
                <li><a href="/blog" class="hover:text-primary transition-colors">Blog</a></li>
                <li class="text-gray-400" aria-hidden="true">/</li>
                <li class="text-gray-700 truncate max-w-xs font-medium" aria-current="page">{post.title}</li>
            </ol>
        </div>
    </nav>

    <main>
        <div class="site-container mx-auto px-4 py-12">
            <div class="lg:grid lg:grid-cols-[1fr_320px] lg:gap-16">

                <!-- Konten Artikel Utama -->
                <div>
                    <!-- Header Artikel -->
                    <header class="mb-10">
                        {post.categories && post.categories.length > 0 && (
                            <div class="flex flex-wrap gap-2 mb-5">
                                {post.categories.map((cat: {title: string}) => (
                                    <span class="inline-block bg-secondary/15 text-secondary-dark text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                                        {cat.title}
                                    </span>
                                ))}
                            </div>
                        )}
                        <h1 class="text-headline mb-5 leading-tight">{post.title}</h1>
                        <div class="flex items-center gap-6 text-sm text-gray-500">
                            <span class="flex items-center gap-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                <Date date={post.publishDate} />
                            </span>
                            <span class="flex items-center gap-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                {readTime} menit baca
                            </span>
                        </div>
                    </header>

                    <!-- Featured Image -->
                    {featuredImageUrl && (
                        <div class="mb-10 rounded-xl overflow-hidden shadow-md">
                            <img
                                src={urlFor(post.featuredImage).width(1200).height(630).format('webp').quality(80).url()}
                                alt={post.featuredImage.alt || post.title}
                                class="w-full h-auto"
                                width="1200"
                                height="630"
                                loading="eager"
                            />
                        </div>
                    )}

                    <!-- Konten artikel — sepenuhnya SSG, bukan client:load -->
                    <article>
                        {bodyHtml ? (
                            <div class="prose prose-lg max-w-none prose-headings:text-headline prose-a:text-primary prose-strong:text-headline prose-blockquote:border-secondary" set:html={bodyHtml} />
                        ) : (
                            <p class="text-gray-500 italic">Konten artikel tidak tersedia.</p>
                        )}
                    </article>

                    <!-- CTA Box dalam artikel -->
                    <div class="mt-12 p-8 bg-primary rounded-xl text-white" data-aos="fade-up">
                        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
                            <div class="flex-1">
                                <h3 class="text-white text-xl font-bold mb-2">Butuh Bantuan Studi Kelayakan?</h3>
                                <p class="text-white/80 text-sm leading-relaxed">Tim konsultan Jakobi siap membantu Anda menyusun studi kelayakan bisnis yang akurat dan komprehensif.</p>
                            </div>
                            <a
                                href="https://wa.me/6281274203815?text=Halo%20Jakobi%2C%20saya%20baca%20artikel%20di%20blog%20dan%20ingin%20konsultasi."
                                target="_blank"
                                rel="noopener noreferrer"
                                class="shrink-0 inline-flex items-center gap-2 bg-secondary text-white font-bold px-6 py-3 rounded-lg hover:bg-secondary-dark transition-colors text-sm"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-4 h-4 fill-current" aria-hidden="true"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
                                Chat WhatsApp
                            </a>
                        </div>
                    </div>

                    <!-- Tombol Share -->
                    <div class="mt-8 pt-8 border-t border-gray-200">
                        <p class="text-sm font-semibold text-gray-700 mb-3">Bagikan artikel ini:</p>
                        <div class="flex flex-wrap gap-3">
                            <a
                                href={`https://wa.me/?text=${encodeURIComponent(post.title + ' — Baca di: ' + Astro.url.href)}`}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 text-sm bg-[#25D366] text-white px-4 py-2 rounded-lg hover:opacity-90 transition-opacity font-medium"
                                aria-label="Bagikan ke WhatsApp"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-4 h-4 fill-current" aria-hidden="true"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
                                WhatsApp
                            </a>
                            <a
                                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 text-sm bg-[#0077B5] text-white px-4 py-2 rounded-lg hover:opacity-90 transition-opacity font-medium"
                                aria-label="Bagikan ke LinkedIn"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-4 h-4 fill-current" aria-hidden="true"><path d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"/></svg>
                                LinkedIn
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                <aside class="mt-12 lg:mt-0">
                    <div class="sticky top-32 space-y-6">
                        <!-- CTA Konsultasi -->
                        <div class="p-6 bg-primary/5 border border-primary/20 rounded-xl">
                            <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center mb-4">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            </div>
                            <h3 class="font-bold text-headline text-lg mb-2">Konsultasi Gratis</h3>
                            <p class="text-sm text-body-base mb-5 leading-relaxed">Diskusikan kebutuhan studi kelayakan bisnis Anda dengan tim ahli kami — tanpa biaya.</p>
                            <a
                                href="https://wa.me/6281274203815?text=Halo%20Jakobi%2C%20saya%20ingin%20konsultasi%20gratis."
                                target="_blank"
                                rel="noopener noreferrer"
                                class="block w-full text-center bg-primary text-white font-semibold py-3 rounded-lg hover:bg-primary-dark transition-colors text-sm"
                            >
                                Chat via WhatsApp
                            </a>
                            <a
                                href="/layanan"
                                class="block w-full text-center border border-primary/30 text-primary font-semibold py-3 rounded-lg hover:bg-primary/5 transition-colors text-sm mt-2"
                            >
                                Lihat Layanan Kami
                            </a>
                        </div>

                        <!-- Layanan singkat -->
                        <div class="p-6 bg-background-light rounded-xl">
                            <h3 class="font-bold text-headline text-base mb-4">Layanan Jakobi</h3>
                            <ul class="space-y-3 text-sm">
                                {[
                                    { name: 'Studi Kelayakan', href: '/jasa-studi-kelayakan-bisnis' },
                                    { name: 'Business Plan', href: '/jasa-business-plan' },
                                    { name: 'Riset Pasar', href: '/jasa-riset-pasar' },
                                    { name: 'Konsultasi Bisnis', href: '/layanan' },
                                ].map(s => (
                                    <li>
                                        <a href={s.href} class="flex items-center gap-2 text-body-base hover:text-primary transition-colors">
                                            <span class="w-1.5 h-1.5 rounded-full bg-secondary shrink-0"></span>
                                            {s.name}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </main>
</Layout>
